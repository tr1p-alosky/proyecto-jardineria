generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---
enum Role {
  ADMIN
  RH
  JEFE_CUADRILLA
  EMPLEADO
}

enum Estado_laboral {
  activo
  inactivo
  onboarding // Añadido para el requerimiento RF08
}

enum Tipo_permiso {
  VACACION
  CITA_MEDICA
  ASUNTOS_PERSONALES
}

enum Estado_solicitud {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum Prioridad {
  ALTA
  MEDIA
  BAJA
}

// --- MODELOS ---
model Personal {
  id_empleado        String          @id // Ej: "003-BV"
  nombre_completo    String
  email_corporativo  String          @unique
  password           String          // ¡Añadido para el Login!
  role               Role            @default(EMPLEADO)
  telefono           String?         // Opcional
  cargo              String
  departamento       String
  direccion          String?         // Opcional
  fecha_nacimiento   DateTime?       // Opcional
  estado_laboral     Estado_laboral? @default(activo)
  dias_disponibles   Int             @default(14)

  asistencias        Asistencia_nomina[]
  permisos           Permisos[]
  formaciones        Formacion[]
  proyectos          Proyecto[]
}

model Asistencia_nomina {
  id_registro        Int       @id @default(autoincrement())
  id_empleado        String
  hora_entrada       DateTime  @default(now())
  hora_salida        DateTime?
  ganancias_dia      Decimal   @db.Decimal(10, 2)
  bonos_activos      Decimal   @db.Decimal(10, 2)

  empleado           Personal  @relation(fields: [id_empleado], references: [id_empleado])
}

model Permisos {
  id_solicitud       Int               @id @default(autoincrement())
  id_empleado        String
  tipo_permiso       Tipo_permiso
  fecha_inicio       DateTime
  fecha_fin          DateTime
  estado             Estado_solicitud  @default(PENDIENTE)

  empleado           Personal          @relation(fields: [id_empleado], references: [id_empleado])
}

model Formacion {
  id_formacion       Int       @id @default(autoincrement())
  id_empleado        String
  nombre_curso       String    // Ej: "Diseño Biofílico Avanzado"
  progreso           Int       @default(0)
  fecha_expiracion   DateTime
  reconocimiento     String?   // Ej: "Top 5% Company Talent"

  empleado           Personal  @relation(fields: [id_empleado], references: [id_empleado])
}

model Proyecto {
  id_proyecto        Int       @id @default(autoincrement())
  id_empleado        String
  nombre_proyecto    String
  tipo_tarea         String
  prioridad          Prioridad @default(MEDIA)
  progreso_proyecto  Int       @default(0)

  responsable        Personal  @relation(fields: [id_empleado], references: [id_empleado])
}